# Copy this file to ".env" and fill in real values. NEVER commit ".env" — it's git-ignored.
# Your app reads these at runtime (via python-dotenv or process.env). Add only what your project needs.

# Example — a database connection string:
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Example — an AI / API key (only if your app calls a model or service at runtime):
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
